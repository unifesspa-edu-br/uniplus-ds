# Normaliza fim de linha para LF no repositório, independente do SO do dev.
# Evita diffs de "linha inteira mudou" por CRLF/LF ao salvar no VSCode.
* text=auto eol=lf

# Arquivos binários: nunca normalizar nem diffar como texto.
*.png  binary
*.svg  text eol=lf
*.woff2 binary
*.ico  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
